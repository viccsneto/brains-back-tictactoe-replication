{
  "name": "@anonymousforpublication/brains-back",
  "version": "1.0.0",
  "description": "A CLI tool for implementing Mastery-Aware Pipelines for LLM-assisted software development",
  "main": "index.js",
  "bin": {
    "brainsback": "./dist/brainsback.js"
  },
  "scripts": {
    "build": "esbuild bin/brainsback.js --bundle --platform=node --target=node16 --outfile=dist/brainsback.js",
    "prepack": "npm run build",
    "start": "node bin/brainsback.js",
    "test": "jest",
    "dev": "nodemon bin/brainsback.js"
  },
  "keywords": [
    "cli",
    "llm",
    "software-engineering",
    "code-review",
    "mastery",
    "agentic-workflow"
  ],
  "author": "Anonymous <anonymous@anonymousland.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anonymousforpublication/brains-back.git"
  },
  "bugs": {
    "url": "https://github.com/anonymousforpublication/brains-back/issues"
  },
  "homepage": "https://github.com/anonymousforpublication/brains-back#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "lib/",
    "templates/",
    "README.md"
  ]
}
